<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ImgApp</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <!-- Zpracování obrázků (ekvivalent Pillow). Licence: Six Labors Split License 1.0
         – zdarma pro projekty s příjmem pod 1 M USD/rok, jinak komerční licence. -->
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.*" />
    <!-- FTP/FTPS klient (ekvivalent ftplib/FTP_TLS) -->
    <PackageReference Include="FluentFTP" Version="51.*" />
  </ItemGroup>
</Project>
